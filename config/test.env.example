# Example environment for integration tests
# Copy this file to config/test.env and fill in values locally. Do NOT commit config/test.env.
# Tests will also honor CI variables when running in GitLab CI.

# Base URL of your GitLab instance (default: https://gitlab.com)
TEST_GITLAB_URL=https://gitlab.com

# Personal Access Token for API tests. In CI, set a protected masked variable named TEST_API_PAT,
# or rely on the built-in CI_JOB_TOKEN for limited-scope operations. Some tests will skip if not set.
TEST_API_PAT=

# Set to 1 if the PAT has admin privileges and you want to run instance-level runner tests
# (uses /runners/all which requires admin). Leave unset or 0 to skip those tests.
TEST_REQUIRE_ADMIN=
